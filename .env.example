# ─── Required ────────────────────────────────────────────────────────────────
# Discord bot token (from Discord Developer Portal → Bot → Token)
DISCORD_TOKEN=your_bot_token_here

# Application / Client ID (from Discord Developer Portal → General Information)
DISCORD_CLIENT_ID=your_application_id_here

# ─── Optional — defaults shown ───────────────────────────────────────────────
# SQLite database path (relative to working directory inside container)
DATABASE_URL=sqlite://data/bot.db

# Reddit API User-Agent — required by Reddit's API rules.
# Format: <platform>:<app_id>:<version> (by /u/<reddit_username>)
REDDIT_USER_AGENT=discord-meme-bot/1.0 (by /u/your_reddit_username)

# Log verbosity: trace | debug | info | warn | error
LOG_LEVEL=info
